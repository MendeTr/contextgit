# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
*.js.map
*.d.ts.map

# SQLite databases (machine-local, never committed)
~/.contexthub/
*.db
*.db-shm
*.db-wal

# ContextGit in-repo context DB — committed to git so context travels with clones
!.contextgit/context.db

# Environment
.env
.env.local

# ContextGit local config — credentials go in env vars, not here
# .contextgit/config.json is committed (no secrets)

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*.worktrees/
